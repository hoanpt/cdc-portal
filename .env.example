# ===========================
# CDC PORTAL v2 — Environment
# ===========================
# Sao chép file này thành .env.local và điền giá trị thật vào

# --- Google Drive ---
# Tạo Service Account tại: https://console.cloud.google.com
# Tải JSON key, đặt đường dẫn tuyệt đối vào đây
GOOGLE_DRIVE_KEY_FILE=./config/google-drive-key.json
# ID thư mục Google Drive nơi lưu file hồ sơ
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# --- Email (Nodemailer) ---
# Để trống nếu chưa có SMTP — hệ thống vẫn hoạt động bình thường
# Với Gmail: bật 2FA, tạo App Password tại myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="CDC Đà Nẵng <your_email@gmail.com>"

# --- Auth ---
# Thay bằng chuỗi ngẫu nhiên mạnh trước khi deploy (ít nhất 32 ký tự)
JWT_SECRET=change-this-to-a-long-random-secret-string-before-deploy

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_ORG_NAME=Trung tâm Kiểm soát Bệnh tật TP. Đà Nẵng
NEXT_PUBLIC_ORG_SHORT=CDC Đà Nẵng

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/cdc_portal

# --- Backup ---
BACKUP_DIR=./data/backups
BACKUP_KEEP_DAYS=30
